{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "main",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/system/main.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/system",
        },
        {
            "name": "main_quick",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/system/main.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/system",
            "args": ["-gr", "1"]
        },
        {
            "name": "main_centralized_quick",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/system/main.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/system",
            "args": ["-gr", "1", "--centralized", "--algorithm", "Centralized_RUL"]
        },
        {
            "name": "main_centralized_client_quick",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/system/main.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/system",
            "args": ["-gr", "1", "--algorithm", "Centralized_RUL", "--centralized-client", "1"]
        }
    ]
}